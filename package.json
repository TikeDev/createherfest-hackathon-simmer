{
  "name": "simmer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "setup:python": "python3 -m pip install -r requirements.txt",
    "dev": "vite",
    "dev:full": "vercel dev --yes --listen 5173",
    "dev:browser": "vercel dev --yes --listen 5173 & wait-on http://localhost:5173 && ./scripts/launch-chrome-beta.sh",
    "dev:browser:fresh": "vercel dev --yes --listen 5173 & wait-on http://localhost:5173 && ./scripts/launch-chrome-beta.sh --fresh",
    "dev:browser:brave": "vercel dev --yes --listen 5173 & wait-on http://localhost:5173 && .\\scripts\\launch-brave.bat",
    "dev:browser:brave:fresh": "vercel dev --yes --listen 5173 & wait-on http://localhost:5173 && .\\scripts\\launch-brave.bat --fresh",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@mozilla/readability": "^0.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.0",
    "lucide-react": "^0.577.0",
    "openai": "^4.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.2.0",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3"
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.6.9",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vercel": "^50.28.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
